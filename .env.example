# Document ChatBot API - Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# OpenRouter API Key - Get yours at https://openrouter.ai/keys
# This is used for both embeddings and LLM generation
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# JWT Secret Key - Generate a secure random string
# You can use: openssl rand -hex 32
SECRET_KEY=your-secret-key-here-minimum-32-characters-long

# =============================================================================
# OPTIONAL VARIABLES (with sensible defaults)
# =============================================================================

# JWT Algorithm (default: HS256)
# ALGORITHM=HS256

# JWT Token Expiration (default: 30 minutes)
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh Token Expiration (default: 24 hours / 1440 minutes)
# REFRESH_TOKEN_EXPIRE_MINUTES=1440

# Database URL (default: SQLite)
# SQLALCHEMY_DATABASE_URL=sqlite:///./chatbot.db

# OpenRouter Model for LLM (default: gpt-3.5-turbo via OpenRouter)
# OPENAI_MODEL=openai/gpt-3.5-turbo

# Qdrant Connection URL (default: local Docker instance)
# QDRANT_URL=http://localhost:6333

# Qdrant Collection Name (default: aprendizaje)
# QDRANT_COLLECTION=aprendizaje

# Rate Limiting - Requests per window (default: 100)
# RATE_LIMIT_REQUESTS=100

# Rate Limiting - Window in seconds (default: 3600 = 1 hour)
# RATE_LIMIT_WINDOW=3600
